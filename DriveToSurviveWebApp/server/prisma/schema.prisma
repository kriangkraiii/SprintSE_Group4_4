generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String              @id @default(cuid())
  username                String              @unique
  email                   String              @unique
  password                String
  firstName               String?
  lastName                String?
  gender                  String?
  phoneNumber             String?
  profilePicture          String?
  nationalIdNumber        String?             @unique
  nationalIdPhotoUrl      String?             @unique @db.VarChar(500)
  nationalIdExpiryDate    DateTime?
  selfiePhotoUrl          String?             @db.VarChar(500)
  role                    Role                @default(PASSENGER)
  isVerified              Boolean             @default(false)
  isActive                Boolean             @default(true)
  otpCode                 String?
  lastLogin               DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?
  passengerSuspendedUntil DateTime?
  driverSuspendedUntil    DateTime?
  otpExpiry               DateTime?
  nationalIdBackNumber    String?
  nationalIdBackPhotoUrl  String?             @db.VarChar(500)
  nationalIdOcrData       String?             @db.LongText
  verifiedByOcr           Boolean             @default(false)
  bookings                Booking[]           @relation("PassengerBookings")
  sentMessages            ChatMessage[]       @relation("MessageSender")
  chatReports             ChatReport[]        @relation("ChatReporter")
  driverChatSessions      ChatSession[]       @relation("DriverChatSessions")
  passengerChatSessions   ChatSession[]       @relation("PassengerChatSessions")
  driverStats             DriverStats?
  driverVerification      DriverVerification?
  notification            Notification[]
  recentSearches          RecentSearch[]
  reviewDisputes          ReviewDispute[]
  driverReviews           RideReview[]        @relation("ReviewDriver")
  passengerReviews        RideReview[]        @relation("ReviewPassenger")
  createdRoutes           Route[]             @relation("DriverRoutes")
  savedPlaces             SavedPlace[]
  vehicles                Vehicle[]

  @@index([role])
  @@index([isActive])
  @@index([isVerified])
  @@index([createdAt])
  @@index([deletedAt])
}

model DriverVerification {
  id                 String             @id @default(cuid())
  userId             String             @unique
  licenseNumber      String             @unique
  firstNameOnLicense String
  lastNameOnLicense  String
  licenseIssueDate   DateTime
  licenseExpiryDate  DateTime
  licensePhotoUrl    String             @db.VarChar(500)
  selfiePhotoUrl     String             @db.VarChar(500)
  typeOnLicense      LicenseType
  status             VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  ocrData            String?            @db.LongText
  verifiedByOcr      Boolean            @default(false)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([licenseIssueDate])
  @@index([licenseExpiryDate])
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  type            NotificationType @default(SYSTEM)
  title           String
  body            String           @db.Text
  link            String?
  metadata        String?          @db.LongText
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  adminReviewedAt DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([adminReviewedAt])
}

model Vehicle {
  id           String           @id @default(cuid())
  userId       String
  vehicleModel String
  licensePlate String           @unique
  vehicleType  String
  color        String
  seatCapacity Int
  photos       String?          @db.LongText
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  routes       Route[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amenities    VehicleAmenity[]

  @@index([userId])
  @@index([createdAt])
  @@index([vehicleType])
  @@index([seatCapacity])
}

model VehicleAmenity {
  id        Int     @id @default(autoincrement())
  vehicleId String
  name      String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Route {
  id              String      @id @default(cuid())
  driverId        String
  vehicleId       String
  startLocation   String      @db.LongText
  endLocation     String      @db.LongText
  departureTime   DateTime
  availableSeats  Int
  pricePerSeat    Float
  conditions      String?     @db.Text
  status          RouteStatus @default(AVAILABLE)
  cancelledAt     DateTime?
  cancelledBy     String?
  routePolyline   String?     @db.MediumText
  distanceMeters  Int?
  durationSeconds Int?
  routeSummary    String?     @db.Text
  distance        String?
  duration        String?
  waypoints       String?     @db.LongText
  landmarks       String?     @db.LongText
  steps           String?     @db.LongText
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  bookings        Booking[]
  driver          User        @relation("DriverRoutes", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
  @@index([departureTime])
}

model Booking {
  id                   String                @id @default(cuid())
  routeId              String
  passengerId          String
  numberOfSeats        Int
  status               BookingStatus         @default(PENDING)
  cancelledAt          DateTime?
  cancelledBy          String?
  cancelReason         CancelReason?
  pickupLocation       String                @db.LongText
  dropoffLocation      String                @db.LongText
  createdAt            DateTime              @default(now())
  completedAt          DateTime?
  noShowDeadline       DateTime?
  arrivalNotifications ArrivalNotification[]
  passenger            User                  @relation("PassengerBookings", fields: [passengerId], references: [id], onDelete: Cascade)
  route                Route                 @relation(fields: [routeId], references: [id], onDelete: Cascade)
  chatSession          ChatSession?
  reviews              RideReview[]

  @@index([passengerId], map: "Booking_passengerId_fkey")
  @@index([routeId], map: "Booking_routeId_fkey")
}

model ChatSession {
  id                 String            @id @default(cuid())
  bookingId          String            @unique
  driverId           String
  passengerId        String
  status             ChatSessionStatus @default(ACTIVE)
  createdAt          DateTime          @default(now())
  endedAt            DateTime?
  retentionExpiresAt DateTime
  messages           ChatMessage[]
  chatReports        ChatReport[]
  booking            Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver             User              @relation("DriverChatSessions", fields: [driverId], references: [id], onDelete: Cascade)
  passenger          User              @relation("PassengerChatSessions", fields: [passengerId], references: [id], onDelete: Cascade)
  voiceCalls         VoiceCallLog[]

  @@index([driverId])
  @@index([passengerId])
  @@index([status])
  @@index([retentionExpiresAt])
}

model ChatMessage {
  id              String       @id @default(cuid())
  sessionId       String
  senderId        String
  type            MessageType  @default(TEXT)
  content         String       @db.Text
  originalContent String?      @db.Text
  isFiltered      Boolean      @default(false)
  isUnsent        Boolean      @default(false)
  unsendDeadline  DateTime?
  metadata        String?      @db.LongText
  createdAt       DateTime     @default(now())
  sender          User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  session         ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reports         ChatReport[]

  @@index([sessionId, createdAt])
  @@index([senderId])
}

model VoiceCallLog {
  id                 String      @id @default(cuid())
  sessionId          String
  callerId           String
  receiverId         String
  duration           Int         @default(0)
  status             String      @default("INITIATED")
  createdAt          DateTime    @default(now())
  endedAt            DateTime?
  retentionExpiresAt DateTime
  session            ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([retentionExpiresAt])
}

model ChatReport {
  id         String       @id @default(cuid())
  sessionId  String
  messageId  String
  reporterId String
  reason     ReportReason
  detail     String?      @db.Text
  status     ReportStatus @default(PENDING)
  adminNote  String?      @db.Text
  createdAt  DateTime     @default(now())
  message    ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter   User         @relation("ChatReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  session    ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([messageId, reporterId])
  @@index([sessionId])
  @@index([status])
  @@index([reporterId], map: "ChatReport_reporterId_fkey")
}

model ArrivalNotification {
  id          String     @id @default(cuid())
  bookingId   String
  driverId    String
  passengerId String
  radiusType  RadiusType
  driverLat   Float?
  driverLon   Float?
  appStatus   String     @default("SENT")
  emailStatus String     @default("SENT")
  triggeredAt DateTime   @default(now())
  booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, radiusType])
  @@index([bookingId])
  @@index([driverId])
}

model NotificationLog {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(50)
  channel     String   @db.VarChar(20)
  recipientId String
  bookingId   String?
  payload     String?  @db.LongText
  status      String   @db.VarChar(30)
  createdAt   DateTime @default(now())

  @@index([recipientId])
  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
}

model RideReview {
  id              String          @id @default(cuid())
  bookingId       String
  passengerId     String
  driverId        String
  rating          Int
  tags            String?         @db.LongText
  comment         String?         @db.Text
  privateFeedback String?         @db.Text
  isAnonymous     Boolean         @default(false)
  displayName     String          @default("")
  status          ReviewStatus    @default(ACTIVE)
  createdAt       DateTime        @default(now())
  disputes        ReviewDispute[]
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver          User            @relation("ReviewDriver", fields: [driverId], references: [id], onDelete: Cascade)
  passenger       User            @relation("ReviewPassenger", fields: [passengerId], references: [id], onDelete: Cascade)

  @@unique([bookingId, passengerId])
  @@index([driverId])
  @@index([passengerId])
  @@index([status])
  @@index([createdAt])
}

model ReviewDispute {
  id         String        @id @default(cuid())
  reviewId   String
  driverId   String
  reason     DisputeReason
  detail     String        @db.Text
  status     DisputeStatus @default(PENDING)
  adminNote  String?       @db.Text
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  driver     User          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  review     RideReview    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, driverId])
  @@index([status])
  @@index([createdAt])
  @@index([driverId], map: "ReviewDispute_driverId_fkey")
}

model DriverStats {
  id           String   @id @default(cuid())
  driverId     String   @unique
  totalRides   Int      @default(0)
  totalReviews Int      @default(0)
  avgRating    Float    @default(0)
  tagCounts    String?  @db.LongText
  updatedAt    DateTime @updatedAt
  driver       User     @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([avgRating])
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  label     String
  name      String
  address   String?  @db.Text
  lat       Float
  lng       Float
  placeId   String?
  icon      String?  @default("pin")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@index([userId])
}

model RecentSearch {
  id      String   @id @default(cuid())
  userId  String
  name    String
  address String?  @db.Text
  lat     Float
  lng     Float
  placeId String?
  usedAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model SystemLog {
  id          Int      @id @default(autoincrement())
  userId      String?
  ipAddress   String?  @db.VarChar(45)
  action      String   @db.VarChar(50)
  resource    String?  @db.Text
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  detail      String?  @db.Text
  entity      String?  @db.VarChar(50)
  entityId    String?  @db.VarChar(100)
  performedBy String?

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([ipAddress])
  @@index([entity])
}

model Blacklist {
  id               Int      @id @default(autoincrement())
  nationalIdHash   String   @unique @db.VarChar(64)
  reason           String?  @db.Text
  createdByAdminId String
  createdAt        DateTime @default(now())
  bannedRole       String   @default("BOTH") @db.VarChar(10)

  @@index([createdAt])
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RouteStatus {
  AVAILABLE
  FULL
  COMPLETED
  CANCELLED
  IN_TRANSIT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

enum CancelReason {
  CHANGE_OF_PLAN
  FOUND_ALTERNATIVE
  DRIVER_DELAY
  PRICE_ISSUE
  WRONG_LOCATION
  DUPLICATE_OR_WRONG_DATE
  SAFETY_CONCERN
  WEATHER_OR_FORCE_MAJEURE
  COMMUNICATION_ISSUE
}

enum LicenseType {
  PRIVATE_CAR_TEMPORARY
  PRIVATE_CAR
  PUBLIC_CAR
  LIFETIME
}

enum NotificationType {
  SYSTEM
  VERIFICATION
  BOOKING
  ROUTE
  CHAT
  ARRIVAL
  REVIEW
}

enum ChatSessionStatus {
  ACTIVE
  ENDED
}

enum MessageType {
  TEXT
  LOCATION
  QUICK_REPLY
  SYSTEM
}

enum RadiusType {
  FIVE_KM
  ONE_KM
  ZERO_KM
  MANUAL
}

enum ReviewStatus {
  ACTIVE
  ANONYMIZED
  HIDDEN
}

enum DisputeStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ReportReason {
  HARASSMENT
  SPAM
  INAPPROPRIATE
  PRIVACY_VIOLATION
  OTHER
}

enum DisputeReason {
  FAKE_REVIEW
  WRONG_PERSON
  INACCURATE
  OFFENSIVE
  OTHER
}
